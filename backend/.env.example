# Smart Inventory Hub — Backend Environment Variables

# Fernet/PBKDF2 secret for encrypting marketplace credentials
ENCRYPTION_SECRET=change-me-in-production

# Postman Mock Service base URL for Trendyol integration (never use live API)
TRENDYOL_MOCK_BASE_URL=https://YOUR-POSTMAN-MOCK-ID.mock.pstmn.io

# NLP cosine similarity threshold for title unification (0.0 – 1.0)
NLP_SIMILARITY_THRESHOLD=0.8

# Firebase Admin SDK service account path (relative to backend/)
FIREBASE_CREDENTIALS_PATH=service-account.json

# Firestore collection names
PRODUCTS_COLLECTION=unified_products
ORDERS_COLLECTION=orders
STOCK_TRANSACTIONS_COLLECTION=stock_transactions
RAW_PRODUCTS_COLLECTION=raw_products
USERS_COLLECTION=Users
